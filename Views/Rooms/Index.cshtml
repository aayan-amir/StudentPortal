@model IReadOnlyList<ClassRoom>

@{
    ViewData["Title"] = "Rooms";
}

<section class="portal-header">
    <div>
        <p class="eyebrow">Rooms</p>
        <h1>Rooms</h1>
        <p class="page-subtitle">Find notes, PDFs, images, and links shared for each class.</p>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a class="btn btn-primary" asp-controller="Admin" asp-action="CreateRoom">Create room</a>
    }
</section>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (Model.Count == 0)
{
    <section class="empty-state">
        <h2>No rooms yet</h2>
        <p>Create a room first, then students can start sending in notes and files.</p>
        <a class="btn btn-primary" asp-controller="Admin" asp-action="CreateRoom">Create first room</a>
    </section>
}
else
{
    <section class="room-grid">
        @foreach (var room in Model)
        {
            <article class="room-card">
                <div>
                    <p class="room-subject">@room.Subject</p>
                    <h2>@room.Name</h2>
                    <p>@room.Description</p>
                </div>
                <div class="room-meta">
                    <span>@room.Section</span>
                    <span>@room.ContentItems.Count approved items</span>
                </div>
                <a class="stretched-link" asp-controller="Rooms" asp-action="Details" asp-route-id="@room.Id">
                    Open room
                </a>
            </article>
        }
    </section>
}

@model StudentPortal.Models.ViewModels.RoomDetailsViewModel

@{
    ViewData["Title"] = Model.Room.Name;
}

<section class="portal-header">
    <div>
        <p class="eyebrow">@Model.Room.Subject - @Model.Room.Section</p>
        <h1>@Model.Room.Name</h1>
        <p class="page-subtitle">@Model.Room.Description</p>
    </div>
    <a class="btn btn-outline-dark" asp-controller="Rooms" asp-action="Index">All rooms</a>
</section>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

<div class="portal-layout">
    <section>
        <div class="section-title">
            <h2>Shared in this room</h2>
            <span>@Model.ApprovedContent.Count items</span>
        </div>

        @if (Model.ApprovedContent.Count == 0)
        {
            <div class="empty-state compact">
                <h3>Nothing shared yet</h3>
                <p>Approved notes and files will show up here.</p>
            </div>
        }
        else
        {
            <div class="content-list">
                @foreach (var item in Model.ApprovedContent)
                {
                    <article class="content-card">
                        <div class="content-heading">
                            <span class="badge text-bg-light">@item.ContentType</span>
                            <span>@item.SubmittedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                        </div>
                        <h3>@item.Title</h3>
                        <p>@item.Description</p>

                        @if (item.Files.Count > 0)
                        {
                            <div class="attachment-list">
                                @foreach (var file in item.Files)
                                {
                                    var isPdf = string.Equals(file.MimeType, "application/pdf", StringComparison.OrdinalIgnoreCase);
                                    var isImage = file.MimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
                                    var isVideo = file.MimeType.StartsWith("video/", StringComparison.OrdinalIgnoreCase);
                                    var fileUrl = isPdf
                                        ? Url.Action("Open", "Files", new { id = file.Id })
                                        : file.SecureUrl;
                                    var downloadUrl = Url.Action("Download", "Files", new { id = file.Id });
                                    var viewLabel = isPdf
                                        ? "View PDF"
                                        : isImage
                                            ? "View Image"
                                            : isVideo
                                                ? "View Video"
                                                : "Open File";

                                    <div class="attachment-item">
                                        @if (isImage)
                                        {
                                            <img class="content-image" src="@fileUrl" alt="@file.OriginalFileName" />
                                        }
                                        else if (isPdf)
                                        {
                                            <div class="pdf-file">
                                                <span class="badge text-bg-light">PDF</span>
                                                <strong>@file.OriginalFileName</strong>
                                            </div>
                                        }

                                        <div class="attachment-actions">
                                            <a class="file-link" href="@fileUrl" target="_blank" rel="noopener">@viewLabel</a>
                                            <a class="file-link" href="@downloadUrl">Download</a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(item.ExternalUrl))
                        {
                            <a href="@item.ExternalUrl" target="_blank" rel="noopener">Open link</a>
                        }

                        <p class="submitter">Shared by @item.SubmittedByName</p>
                    </article>
                }
            </div>
        }
    </section>

    <aside class="submit-panel">
        <h2>Share something</h2>
        <form asp-controller="Rooms" asp-action="Submit" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>
            <input asp-for="Submission.ClassRoomId" type="hidden" />

            <div class="mb-3">
                <label asp-for="Submission.SubmittedByName" class="form-label">Your name</label>
                <input asp-for="Submission.SubmittedByName" class="form-control" />
                <span asp-validation-for="Submission.SubmittedByName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Submission.Title" class="form-label">Title</label>
                <input asp-for="Submission.Title" class="form-control" />
                <span asp-validation-for="Submission.Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Submission.ContentType" class="form-label">Type</label>
                <select asp-for="Submission.ContentType" asp-items="Html.GetEnumSelectList<ContentType>()" class="form-select"></select>
            </div>

            <div class="mb-3">
                <label asp-for="Submission.Description" class="form-label">Description</label>
                <textarea asp-for="Submission.Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Submission.Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Submission.ExternalUrl" class="form-label">Link</label>
                <input asp-for="Submission.ExternalUrl" class="form-control" />
                <span asp-validation-for="Submission.ExternalUrl" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Submission.UploadedFile" class="form-label">File upload</label>
                <input asp-for="Submission.UploadedFile" class="form-control" accept="image/jpeg,image/png,image/webp,image/gif,application/pdf" />
                <span asp-validation-for="Submission.UploadedFile" class="text-danger"></span>
            </div>

            <button class="btn btn-primary w-100" type="submit">Send for review</button>
        </form>
    </aside>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model IReadOnlyList<ContentItem>

@{
    ViewData["Title"] = "Pending Approval";
}

<section class="portal-header">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Review queue</h1>
        <p class="page-subtitle">Approve material for room visibility or reject it and remove its uploaded file.</p>
    </div>
    <a class="btn btn-outline-dark" asp-controller="Admin" asp-action="Rooms">Manage rooms</a>
</section>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (Model.Count == 0)
{
    <section class="empty-state">
        <h2>No pending submissions</h2>
        <p>Student submissions waiting for approval will appear here.</p>
    </section>
}
else
{
    <section class="moderation-list">
        @foreach (var item in Model)
        {
            <article class="moderation-item">
                <div>
                    <div class="content-heading">
                        <span class="badge text-bg-warning">@item.ContentType</span>
                        <span>@item.ClassRoom?.Name - @item.SubmittedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                    </div>
                    <h2>@item.Title</h2>
                    <p>@item.Description</p>

                    @if (item.Files.Count > 0)
                    {
                        <div class="attachment-list">
                            @foreach (var file in item.Files)
                            {
                                var isPdf = string.Equals(file.MimeType, "application/pdf", StringComparison.OrdinalIgnoreCase);
                                var isImage = file.MimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
                                var fileUrl = isPdf
                                    ? Url.Action("Open", "Files", new { id = file.Id })
                                    : file.SecureUrl;

                                <div class="attachment-item">
                                    @if (isImage)
                                    {
                                        <img class="content-image moderation-image" src="@fileUrl" alt="@file.OriginalFileName" />
                                    }
                                    else if (isPdf)
                                    {
                                        <div class="pdf-file">
                                            <span class="badge text-bg-light">PDF</span>
                                            <strong>@file.OriginalFileName</strong>
                                        </div>
                                    }

                                    <a class="file-link" href="@fileUrl" target="_blank" rel="noopener">
                                        @(isPdf ? "View PDF" : "Open File")
                                    </a>
                                </div>
                            }
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(item.ExternalUrl))
                    {
                        <a href="@item.ExternalUrl" target="_blank" rel="noopener">Open submitted link</a>
                    }

                    <p class="submitter">Submitted by @item.SubmittedByName</p>
                </div>

                <div class="approval-actions">
                    <form asp-controller="Admin" asp-action="Approve" asp-route-id="@item.Id" method="post">
                        <button class="btn btn-success w-100" type="submit">Approve</button>
                    </form>
                    <form asp-controller="Admin" asp-action="Reject" asp-route-id="@item.Id" method="post">
                        <button class="btn btn-outline-danger w-100" type="submit">Reject and delete file</button>
                    </form>
                </div>
            </article>
        }
    </section>
}

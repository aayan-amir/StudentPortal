@{
    var isAdmin = User.Identity?.IsAuthenticated == true;
    var shellClass = ViewData["ShellClass"] as string ?? string.Empty;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Portal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@shellClass">
    <div class="app-shell">
        <aside class="app-rail">
            <div class="app-brand">
                <a asp-controller="Rooms" asp-action="Index">
                    <strong>Student Portal</strong>
                    <small>Notes, links, uploads</small>
                </a>
            </div>

            <nav class="app-nav" aria-label="Main navigation">
                <a asp-controller="Rooms" asp-action="Index">Rooms</a>
                @if (isAdmin)
                {
                    <a asp-controller="Admin" asp-action="Pending">To Review</a>
                    <a asp-controller="Admin" asp-action="Approved">Shared</a>
                    <a asp-controller="Admin" asp-action="Rooms">Manage Rooms</a>
                }
            </nav>

            <div class="app-actions">
                @if (isAdmin)
                {
                    <span class="admin-chip">@User.Identity?.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button class="btn btn-outline-light btn-sm" type="submit">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-light btn-sm" asp-controller="Account" asp-action="Login">Admin</a>
                }
            </div>
        </aside>

        <div class="app-workspace">
            <main class="app-main" role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    @if (Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development")
    {
        <div class="dev-url-badge">
            <span>Local URL</span>
            <strong>@Context.Request.Scheme://@Context.Request.Host</strong>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

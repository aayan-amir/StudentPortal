@model IReadOnlyList<ClassRoom>

@{
    ViewData["Title"] = "Manage Rooms";
}

<section class="portal-header">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Manage rooms</h1>
        <p class="page-subtitle">Maintain the list of class rooms students can submit to.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Admin" asp-action="CreateRoom">Create room</a>
</section>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (Model.Count == 0)
{
    <section class="empty-state">
        <h2>No rooms created</h2>
        <p>Create at least one room before collecting submissions.</p>
    </section>
}
else
{
    <section class="table-panel">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Subject</th>
                    <th>Section</th>
                    <th>Description</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var room in Model)
                {
                    <tr>
                        <td>@room.Name</td>
                        <td>@room.Subject</td>
                        <td>@room.Section</td>
                        <td>@room.Description</td>
                        <td>
                            <a asp-controller="Rooms" asp-action="Details" asp-route-id="@room.Id">Open</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}

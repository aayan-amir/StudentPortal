@model IReadOnlyList<ClassRoom>

@{
    ViewData["Title"] = "Manage Rooms";
}

<section class="portal-header">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Manage rooms</h1>
        <p class="page-subtitle">Maintain the list of class rooms students can submit to.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Admin" asp-action="CreateRoom">Create room</a>
</section>

@if (TempData["SuccessMessage"] is string message)
{
    <div class="alert alert-success">@message</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (Model.Count == 0)
{
    <section class="empty-state">
        <h2>No rooms created</h2>
        <p>Create at least one room before collecting submissions.</p>
    </section>
}
else
{
    <section class="table-panel">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Subject</th>
                    <th>Section</th>
                    <th>Description</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var room in Model)
                {
                    <tr>
                        <td data-label="Name">@room.Name</td>
                        <td data-label="Subject">@room.Subject</td>
                        <td data-label="Section">@room.Section</td>
                        <td data-label="Description">@room.Description</td>
                        <td data-label="Actions" class="room-actions">
                            <a class="btn btn-outline-dark btn-sm" asp-controller="Rooms" asp-action="Details" asp-route-id="@room.Id">Open</a>
                            <form asp-controller="Admin" asp-action="DeleteRoom" asp-route-id="@room.Id" method="post" onsubmit="return confirm('Delete this room and all of its submissions and uploaded files?');">
                                <button class="btn btn-outline-danger btn-sm" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </section>
}
